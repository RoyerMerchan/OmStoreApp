generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  CASHIER
  SELLER
}

enum Gender {
  MEN
  WOMEN
  BOY
  GIRL
  UNISEX
}

enum StockMovementType {
  PURCHASE
  SALE
  SALE_CANCEL
  LAYAWAY_RESERVE
  LAYAWAY_CANCEL
  LAYAWAY_COMPLETE
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  RETURN
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  MOBILE_PAYMENT
  MIXED
}

enum SaleStatus {
  COMPLETED
  CANCELLED
  REFUNDED
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum LayawayStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  EXPIRED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  CANCEL
  OPEN_CASH
  CLOSE_CASH
  STOCK_ADJUSTMENT
  LOGIN
}

enum CashMovementType {
  INCOME
  EXPENSE
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(SELLER)
  isActive     Boolean  @default(true)

  sales           Sale[]
  cashSessions    CashSession[]
  stockMovements  StockMovement[]
  auditLogs       AuditLog[]
  layaways        Layaway[]
  expenses        Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Brand {
  id       String  @id @default(cuid())
  name     String  @unique
  isActive Boolean @default(true)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id       String  @id @default(cuid())
  name     String  @unique
  isActive Boolean @default(true)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  gender      Gender   @default(UNISEX)
  baseCost    Decimal  @default(0) @db.Decimal(12,2)
  basePrice   Decimal  @default(0) @db.Decimal(12,2)
  imageUrl    String?
  isActive    Boolean  @default(true)

  brandId    String?
  categoryId String?

  brand    Brand?    @relation(fields: [brandId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])
  variants ProductVariant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([brandId])
  @@index([categoryId])
}

model ProductVariant {
  id            String   @id @default(cuid())
  productId     String
  size          String
  color         String
  sku           String   @unique
  barcode       String?  @unique
  cost          Decimal? @db.Decimal(12,2)
  price         Decimal? @db.Decimal(12,2)
  stock         Int      @default(0)
  reservedStock Int      @default(0)
  minStock      Int      @default(1)
  isActive      Boolean  @default(true)

  product        Product         @relation(fields: [productId], references: [id])
  saleItems      SaleItem[]
  purchaseItems  PurchaseItem[]
  stockMovements StockMovement[]
  layawayItems   LayawayItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([size])
  @@index([color])
  @@index([sku])
}

model Customer {
  id        String  @id @default(cuid())
  name      String
  document  String? @unique
  phone     String?
  email     String?
  address   String?
  isActive  Boolean @default(true)

  sales    Sale[]
  layaways Layaway[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([phone])
}

model Supplier {
  id        String  @id @default(cuid())
  name      String
  document  String?
  phone     String?
  email     String?
  address   String?
  isActive  Boolean @default(true)

  purchases Purchase[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Purchase {
  id         String   @id @default(cuid())
  supplierId String?
  invoiceNo  String?
  notes      String?  @db.Text
  total      Decimal  @default(0) @db.Decimal(12,2)

  supplier Supplier?     @relation(fields: [supplierId], references: [id])
  items    PurchaseItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

model PurchaseItem {
  id         String  @id @default(cuid())
  purchaseId String
  variantId  String
  quantity   Int
  unitCost   Decimal @db.Decimal(12,2)
  subtotal   Decimal @db.Decimal(12,2)

  purchase Purchase      @relation(fields: [purchaseId], references: [id])
  variant  ProductVariant @relation(fields: [variantId], references: [id])

  createdAt DateTime @default(now())

  @@index([purchaseId])
}

model Sale {
  id            String     @id @default(cuid())
  saleNumber    String     @unique
  customerId    String?
  userId        String
  cashSessionId String?
  status        SaleStatus @default(COMPLETED)

  subtotal Decimal   @db.Decimal(12,2)
  discount Decimal   @default(0) @db.Decimal(12,2)
  total    Decimal   @db.Decimal(12,2)
  notes    String?   @db.Text

  customer    Customer?     @relation(fields: [customerId], references: [id])
  user        User          @relation(fields: [userId], references: [id])
  cashSession CashSession?  @relation(fields: [cashSessionId], references: [id])
  items       SaleItem[]
  payments    SalePayment[]
  layaway     Layaway?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([userId])
  @@index([cashSessionId])
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  variantId String
  quantity  Int
  unitPrice Decimal @db.Decimal(12,2)
  unitCost  Decimal @default(0) @db.Decimal(12,2)
  discount  Decimal @default(0) @db.Decimal(12,2)
  subtotal  Decimal @db.Decimal(12,2)

  sale    Sale           @relation(fields: [saleId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])

  createdAt DateTime @default(now())

  @@index([saleId])
}

model SalePayment {
  id        String        @id @default(cuid())
  saleId    String
  method    PaymentMethod
  amount    Decimal       @db.Decimal(12,2)
  reference String?

  sale Sale @relation(fields: [saleId], references: [id])

  createdAt DateTime @default(now())

  @@index([saleId])
}

model CashSession {
  id             String           @id @default(cuid())
  userId         String
  status         CashSessionStatus @default(OPEN)

  openingAmount Decimal  @default(0) @db.Decimal(12,2)
  closingAmount Decimal? @db.Decimal(12,2)
  expectedAmount Decimal? @db.Decimal(12,2)
  difference    Decimal? @db.Decimal(12,2)

  openedAt DateTime? @default(now())
  closedAt DateTime?
  notes    String?   @db.Text

  user         User           @relation(fields: [userId], references: [id])
  sales        Sale[]
  cashMovements CashMovement[]
  expenses     Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model CashMovement {
  id            String          @id @default(cuid())
  cashSessionId String
  type          CashMovementType
  concept       String
  amount        Decimal         @db.Decimal(12,2)
  notes         String?         @db.Text

  cashSession CashSession @relation(fields: [cashSessionId], references: [id])

  createdAt DateTime @default(now())

  @@index([cashSessionId])
}

model Layaway {
  id             String        @id @default(cuid())
  layawayNumber  String        @unique
  customerId     String
  userId         String
  saleId         String?       @unique
  status         LayawayStatus @default(ACTIVE)

  subtotal       Decimal  @db.Decimal(12,2)
  initialPayment Decimal  @default(0) @db.Decimal(12,2)
  totalPaid      Decimal  @default(0) @db.Decimal(12,2)
  balance        Decimal  @db.Decimal(12,2)
  dueDate        DateTime
  completedAt    DateTime?
  cancelledAt    DateTime?
  notes          String?  @db.Text

  customer Customer       @relation(fields: [customerId], references: [id])
  user     User           @relation(fields: [userId], references: [id])
  sale     Sale?          @relation(fields: [saleId], references: [id])
  items    LayawayItem[]
  payments LayawayPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([dueDate])
}

model LayawayItem {
  id        String  @id @default(cuid())
  layawayId String
  variantId String
  quantity  Int
  unitPrice Decimal @db.Decimal(12,2)
  subtotal  Decimal @db.Decimal(12,2)

  layaway Layaway        @relation(fields: [layawayId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])

  createdAt DateTime @default(now())

  @@index([layawayId])
}

model LayawayPayment {
  id        String        @id @default(cuid())
  layawayId String
  method    PaymentMethod
  amount    Decimal       @db.Decimal(12,2)
  reference String?
  notes     String?       @db.Text

  layaway Layaway @relation(fields: [layawayId], references: [id])

  createdAt DateTime @default(now())

  @@index([layawayId])
}

model StockMovement {
  id            String            @id @default(cuid())
  variantId     String
  userId        String?
  type          StockMovementType
  quantity      Int
  previousStock Int
  newStock      Int
  reason        String?
  reference     String?

  variant ProductVariant @relation(fields: [variantId], references: [id])
  user    User?          @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([variantId])
  @@index([type])
  @@index([createdAt])
}

model ExpenseCategory {
  id       String  @id @default(cuid())
  name     String  @unique
  isActive Boolean @default(true)

  expenses Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Expense {
  id            String   @id @default(cuid())
  categoryId    String?
  cashSessionId String?
  userId        String?
  concept       String
  amount        Decimal  @db.Decimal(12,2)
  notes         String?  @db.Text

  category    ExpenseCategory? @relation(fields: [categoryId], references: [id])
  cashSession CashSession?    @relation(fields: [cashSessionId], references: [id])
  user        User?           @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([cashSessionId])
  @@index([categoryId])
}

model AuditLog {
  id          String      @id @default(cuid())
  userId      String?
  action      AuditAction
  entity      String
  entityId    String?
  description String?
  metadata    Json?

  user User? @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
}
