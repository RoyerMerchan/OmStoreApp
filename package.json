{
  "name": "omstore",
  "private": true,
  "version": "1.0.0",
  "description": "Sistema administrativo POS para tienda de zapatos",
  "scripts": {
    "setup": "tsx scripts/setup.ts",
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "db:generate": "pnpm --filter @omstore/database run db:generate",
    "db:migrate": "pnpm --filter @omstore/database run db:migrate",
    "db:seed": "pnpm --filter @omstore/database run db:seed",
    "db:push": "pnpm --filter @omstore/database run db:push",
    "db:studio": "pnpm --filter @omstore/database run db:studio",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck"
  },
  "devDependencies": {
    "tsx": "^4.19.0"
  },
  "engines": {
    "node": ">=18"
  }
}
